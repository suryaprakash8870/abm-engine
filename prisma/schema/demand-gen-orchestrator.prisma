// ─────────────────────────────────────────────────────────────────────────────
// Engine 09 — Demand Gen Orchestrator.
//
// "Where intelligence becomes action." Consumes Awareness triggers, evaluates the
// tier×stage play matrix, checks suppression atomically, fires the play (CRM task
// via Engine 10 + Slack + sequence enrolment), and logs it. Tables this engine
// owns (no other engine queries them directly). Every table is workspace-scoped.
// ─────────────────────────────────────────────────────────────────────────────

model PlaysLog {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  accountId       String    @map("account_id")
  contactId       String?   @map("contact_id")
  playType        String    @map("play_type")
  triggerType     String    @map("trigger_type")
  triggerSignalId String?   @map("trigger_signal_id")
  executionMethod String    @map("execution_method")
  status          String    @default("fired") // fired | enrolled | snoozed | suppressed
  crmTaskId       String?   @map("crm_task_id")
  slackMessageTs  String?   @map("slack_message_ts")
  assignedTo      String?   @map("assigned_to")
  outcome         String?
  snoozedUntil    DateTime? @map("snoozed_until")
  correlationId   String?   @map("correlation_id")
  firedAt         DateTime  @default(now()) @map("fired_at")

  @@unique([workspaceId, accountId, correlationId]) // idempotency: one play per trigger event
  @@index([workspaceId, accountId])
  @@index([workspaceId, status])
  @@map("plays_log")
}

model PlayTemplate {
  id              String   @id @default(cuid())
  workspaceId     String   @map("workspace_id")
  playType        String   @map("play_type")
  tier            Int
  stage           String
  executionMethod String   @map("execution_method")
  templateConfig  Json     @map("template_config")
  isActive        Boolean  @default(true) @map("is_active")

  @@unique([workspaceId, tier, stage]) // one active template per tier×stage cell
  @@index([workspaceId])
  @@map("play_templates")
}

model PlayOutcome {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  playId      String   @map("play_id")
  outcome     String
  notes       String?
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([workspaceId, playId])
  @@map("play_outcomes")
}

model SuppressionRule {
  id           String  @id @default(cuid())
  workspaceId  String  @map("workspace_id")
  ruleType     String  @map("rule_type") // cooldown | unsubscribe | not_interested
  cooldownDays Int     @default(7) @map("cooldown_days")
  maxPerMonth  Int     @default(4) @map("max_per_month")
  isActive     Boolean @default(true) @map("is_active")

  @@index([workspaceId])
  @@map("suppression_rules")
}

model SequenceMapping {
  id          String  @id @default(cuid())
  workspaceId String  @map("workspace_id")
  tier        Int
  industry    String?
  role        String?
  sequenceId  String  @map("sequence_id")

  @@index([workspaceId, tier])
  @@map("sequence_mappings")
}

model AiDraftLog {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  playId       String   @map("play_id")
  subjectLines String[] @map("subject_lines")
  body         String
  modelUsed    String   @map("model_used")
  generatedAt  DateTime @default(now()) @map("generated_at")

  @@index([workspaceId, playId])
  @@map("ai_draft_log")
}
