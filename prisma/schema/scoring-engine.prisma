// ─────────────────────────────────────────────────────────────────────────────
// Engine 04 — Scoring Engine
// ─────────────────────────────────────────────────────────────────────────────

model ScoringFormula {
  id             String   @id @default(cuid())
  workspaceId    String   @map("workspace_id")
  icpId          String   @map("icp_id")
  version        Int      @default(1)
  criteria       Json     // ScoringCriterion[] — weights + rationale
  tierBoundaries Json     @map("tier_boundaries") // { tier1_min, tier2_min, tier3_min }
  isFallback     Boolean  @default(false) @map("is_fallback")
  createdBy      String   @default("system") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  versions ScoringFormulaVersion[]

  @@index([workspaceId, icpId])
  @@map("scoring_formulas")
}

model ScoringFormulaVersion {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  formulaId     String   @map("formula_id")
  versionNumber Int      @map("version_number")
  snapshot      Json
  createdAt     DateTime @default(now()) @map("created_at")

  formula ScoringFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@index([workspaceId, formulaId])
  @@map("scoring_formula_versions")
}

model AccountScore {
  id              String   @id @default(cuid())
  workspaceId     String   @map("workspace_id")
  accountId       String   @map("account_id")
  formulaVersion  Int      @map("formula_version")
  totalScore      Float    @map("total_score") // 0-100
  tier            Int?     // 1 | 2 | 3 — null = scored but below tier3_min (untiered, not in TAL)
  criterionScores Json     @map("criterion_scores") // CriterionScore[]
  scoredAt        DateTime @default(now()) @map("scored_at")

  @@unique([workspaceId, accountId])
  @@index([workspaceId])
  @@map("account_scores")
}

model ScoreHistory {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  accountId   String   @map("account_id")
  score       Float
  tier        Int?     // 1 | 2 | 3 — null = untiered (below tier3_min)
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([workspaceId, accountId])
  @@map("score_history")
}

model TierOverride {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  accountId    String   @map("account_id")
  tier         Int      // 1 | 2 | 3 — user override always wins
  reason       String   // required, logged for formula improvement
  overriddenBy String   @map("overridden_by")
  overriddenAt DateTime @default(now()) @map("overridden_at")

  @@index([workspaceId, accountId])
  @@map("tier_overrides")
}
