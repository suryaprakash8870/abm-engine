// ─────────────────────────────────────────────────────────────────────────────
// Engine 02 — TAM Builder · owned by Surya (Member A)
//
// Sources every company matching the ICP. Tables owned here; no other engine
// queries them — they listen to tam.* events and keep local copies.
//
// See docs/engines/engine-02-tam-builder.md.
// ─────────────────────────────────────────────────────────────────────────────

model TamBuildJob {
  id           String    @id @default(cuid())
  workspaceId  String    @map("workspace_id")
  icpId        String    @map("icp_id")
  status       String    @default("running") // running | completed | failed
  totalFound   Int       @default(0) @map("total_found")
  processed    Int       @default(0)
  accountLimit Int       @default(1000) @map("account_limit")
  filters      Json? // search filters derived from the ICP (for re-builds)
  error        String?
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@index([workspaceId])
  @@index([icpId])
  @@map("tam_build_jobs")
}

model ApolloSearchResult {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  rawResponse Json     @map("raw_response")
  pageNumber  Int      @map("page_number")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@map("apollo_search_results")
}

model RawAccount {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  jobId       String   @map("job_id")
  domain      String
  name        String
  apolloId    String?  @map("apollo_id")
  source      String // apollo | csv_upload
  createdAt   DateTime @default(now()) @map("created_at")

  // The dedupe guarantee from the task-completion check.
  @@unique([workspaceId, domain])
  @@index([jobId])
  @@map("raw_account_list")
}

model SearchParamsLog {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  params      Json
  resultCount Int      @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@map("search_params_log")
}
