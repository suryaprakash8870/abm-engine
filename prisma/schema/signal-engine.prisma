// ─────────────────────────────────────────────────────────────────────────────
// Engine 07 — Signal Engine (always-on).
//
// Tracks buying signals (website hits, CRM/email webhooks), resolves each to a
// TAL account, normalises + deduplicates, and publishes signal.received. Tables
// this engine owns (no other engine queries them directly). Every table is
// workspace-scoped (rule #3). signals.(workspace_id, dedup_key) is UNIQUE — the
// durable idempotency backstop on a dedup-cache miss.
// ─────────────────────────────────────────────────────────────────────────────

model Signal {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  accountId        String   @map("account_id")
  contactId        String?  @map("contact_id")
  signalType       String   @map("signal_type")
  signalSource     String   @map("signal_source")
  pointsAwarded    Int      @map("points_awarded")
  decayRatePerWeek Float    @map("decay_rate_per_week")
  pageUrl          String?  @map("page_url")
  metadata         Json?
  dedupKey         String   @map("dedup_key")
  occurredAt       DateTime @map("occurred_at")
  receivedAt       DateTime @default(now()) @map("received_at")

  @@unique([workspaceId, dedupKey]) // idempotency: one signal per (account, type, 5-min bucket)
  @@index([workspaceId, accountId])
  @@index([workspaceId, occurredAt])
  @@map("signals")
}

model SignalSource {
  id          String  @id @default(cuid())
  workspaceId String  @map("workspace_id")
  sourceType  String  @map("source_type")
  config      Json?
  isActive    Boolean @default(true) @map("is_active")

  @@index([workspaceId])
  @@map("signal_sources")
}

model WebhookLog {
  id             String   @id @default(cuid())
  workspaceId    String?  @map("workspace_id")
  source         String
  payload        Json?
  signatureValid Boolean  @map("signature_valid")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@index([workspaceId])
  @@map("webhook_log")
}

model TrackingToken {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  token       String   @unique
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId]) // one active tracking token per workspace
  @@map("tracking_tokens")
}

model VisitorSession {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  sessionId   String   @map("session_id")
  accountId   String?  @map("account_id")
  ipHash      String   @map("ip_hash")
  firstSeen   DateTime @default(now()) @map("first_seen")
  lastSeen    DateTime @default(now()) @map("last_seen")

  @@unique([workspaceId, sessionId])
  @@index([workspaceId, accountId])
  @@map("visitor_sessions")
}
