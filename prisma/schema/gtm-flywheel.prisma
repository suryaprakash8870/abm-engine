// ─────────────────────────────────────────────────────────────────────────────
// Engine 11 — GTM Flywheel (attribution, insights, ICP feedback loop).
//
// Closes the learning loop: on every closed deal it walks back attribution,
// recomputes pipeline/win-rate by tier, and after every 5th win recommends an ICP
// refresh back to Engine 01. Tables this engine owns (no other engine queries them
// directly). Every table is workspace-scoped. Idempotent on deal_id so a
// re-delivered deal event can't double-count revenue.
// ─────────────────────────────────────────────────────────────────────────────

model PipelineSnapshot {
  id                String   @id @default(cuid())
  workspaceId       String   @map("workspace_id")
  date              DateTime @db.Date
  pipelineByTier    Json     @map("pipeline_by_tier")
  winRateByTier     Json     @map("win_rate_by_tier")
  avgDealSizeByTier Json     @map("avg_deal_size_by_tier")
  daysToCloseByTier Json     @map("days_to_close_by_tier")

  @@unique([workspaceId, date]) // one snapshot per day
  @@index([workspaceId, date])
  @@map("pipeline_snapshots")
}

model AttributionEvent {
  id                     String   @id @default(cuid())
  workspaceId            String   @map("workspace_id")
  accountId              String   @map("account_id")
  dealId                 String   @map("deal_id")
  touchType              String   @map("touch_type") // signal | play
  touchSubtype           String?  @map("touch_subtype")
  signalId               String?  @map("signal_id")
  weight                 Float    @default(0) // linear-attribution weight
  occurredBeforePipeline Boolean  @map("occurred_before_pipeline")
  occurredAt             DateTime @map("occurred_at")
  recordedAt             DateTime @default(now()) @map("recorded_at")

  @@index([workspaceId, dealId])
  @@map("attribution_events")
}

model WinLossAnalysis {
  id                String   @id @default(cuid())
  workspaceId       String   @map("workspace_id")
  dealId            String   @map("deal_id")
  accountId         String?  @map("account_id")
  outcome           String // won | lost
  amount            Float?
  accountAttributes Json     @map("account_attributes") // { tier, domain, days_to_close, owner_id }
  closedAt          DateTime @map("closed_at")
  analyzedAt        DateTime @default(now()) @map("analyzed_at")

  @@unique([workspaceId, dealId]) // idempotent: one analysis per deal
  @@index([workspaceId, outcome])
  @@map("win_loss_analysis")
}

model FlywheelMetric {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  metricKey    String   @map("metric_key")
  value        Float
  period       String
  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@unique([workspaceId, metricKey, period]) // upsert keyed metrics
  @@index([workspaceId, metricKey, period])
  @@map("flywheel_metrics")
}

model SignalCorrelationData {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  signalCombination String[] @map("signal_combination")
  correlationScore Float    @map("correlation_score")
  sampleSize       Int      @map("sample_size")
  calculatedAt     DateTime @default(now()) @map("calculated_at")

  @@index([workspaceId])
  @@map("signal_correlation_data")
}
