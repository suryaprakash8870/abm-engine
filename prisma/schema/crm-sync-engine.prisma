// ─────────────────────────────────────────────────────────────────────────────
// Engine 10 — CRM Sync Engine.
//
// The ONLY engine that writes to the CRM (rule #8). Consumes write events from
// upstream engines, batches + rate-limits + upserts them, logs every operation,
// and emits crm.synced; also turns inbound deal webhooks into closed-won/lost.
// Tables this engine owns (no other engine queries them directly). Every table is
// workspace-scoped. OAuth tokens are AES-256-GCM encrypted at rest — never plain.
// ─────────────────────────────────────────────────────────────────────────────

model CrmConnection {
  id              String   @id @default(cuid())
  workspaceId     String   @map("workspace_id")
  crmType         String   @map("crm_type") // hubspot | salesforce
  accessTokenEnc  String   @map("access_token_enc")
  refreshTokenEnc String   @map("refresh_token_enc")
  expiresAt       DateTime @map("expires_at")
  portalId        String?  @map("portal_id")
  instanceUrl     String?  @map("instance_url")
  isActive        Boolean  @default(true) @map("is_active")
  connectedAt     DateTime @default(now()) @map("connected_at")

  @@unique([workspaceId, crmType]) // one connection per CRM per workspace
  @@index([workspaceId])
  @@map("crm_connections")
}

model SyncJob {
  id            String    @id @default(cuid())
  workspaceId   String    @map("workspace_id")
  syncType      String    @map("sync_type")
  status        String    @default("running") // running | completed | partial | failed
  recordsTotal  Int       @default(0) @map("records_total")
  recordsSynced Int       @default(0) @map("records_synced")
  errors        Int       @default(0)
  correlationId String    @map("correlation_id") // always set (source event id); NOT NULL so the unique key actually dedups
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  @@unique([workspaceId, syncType, correlationId]) // idempotency: one job per source event
  @@index([workspaceId])
  @@map("sync_jobs")
}

model SyncLog {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  syncJobId   String   @map("sync_job_id") // always set; NOT NULL so the unique key actually dedups
  recordType  String   @map("record_type")
  recordId    String   @map("record_id")
  operation   String // create | update | upsert
  outcome     String // success | failed | dead_lettered
  apiResponse Json     @map("api_response")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@unique([workspaceId, syncJobId, recordId]) // idempotent re-run of the same job
  @@index([workspaceId, syncedAt])
  @@map("sync_log")
}

model FieldMapping {
  id          String @id @default(cuid())
  workspaceId String @map("workspace_id")
  crmType     String @map("crm_type")
  abmField    String @map("abm_field")
  crmField    String @map("crm_field")

  @@index([workspaceId])
  @@map("field_mappings")
}

model WebhookSubscription {
  id             String @id @default(cuid())
  workspaceId    String @map("workspace_id")
  crmType        String @map("crm_type")
  eventType      String @map("event_type")
  subscriptionId String @map("subscription_id")

  @@index([workspaceId])
  @@map("webhook_subscriptions")
}
