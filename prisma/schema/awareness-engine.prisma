// ─────────────────────────────────────────────────────────────────────────────
// Engine 08 — Awareness Engine.
//
// Turns signals into a decayed, capped (≤100) awareness score + 5-stage funnel
// per account, and evaluates routing rules. Tables this engine owns (no other
// engine queries them directly). Every table is workspace-scoped (rule #3) —
// including the ones the stub left a TODO on.
// ─────────────────────────────────────────────────────────────────────────────

model AwarenessScore {
  id               String    @id @default(cuid())
  workspaceId      String    @map("workspace_id")
  accountId        String    @map("account_id")
  currentScore     Int       @default(0) @map("current_score") // capped at 100
  stage            String    @default("identified") // AwarenessStage
  score7dChange    Int       @default(0) @map("score_7d_change")
  score30dChange   Int       @default(0) @map("score_30d_change")
  lastCalculatedAt DateTime  @default(now()) @map("last_calculated_at")
  lastSignalAt     DateTime? @map("last_signal_at")

  @@unique([workspaceId, accountId])
  @@index([workspaceId, currentScore])
  @@map("awareness_scores")
}

model ScoreSnapshot {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  accountId          String   @map("account_id")
  date               DateTime @db.Date
  score              Int
  dominantSignalType String   @map("dominant_signal_type")

  @@unique([workspaceId, accountId, date])
  @@index([workspaceId, accountId])
  @@map("score_snapshots")
}

model RoutingRule {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  name          String
  isActive      Boolean  @default(true) @map("is_active")
  triggerConfig Json     @map("trigger_config") // { min_score?, stage?, signal_types? }
  actions       String[] // slack_alert | crm_task | email_play | ...
  priority      Int      @default(0)
  cooldownDays  Int      @default(7) @map("cooldown_days")
  maxPerMonth   Int      @default(4) @map("max_per_month")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@map("routing_rules")
}

model RoutingRuleEvaluation {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  ruleId      String    @map("rule_id")
  accountId   String    @map("account_id")
  matched     Boolean   @default(false)
  firedAt     DateTime? @map("fired_at") // null when matched but suppressed by cooldown/cap
  evaluatedAt DateTime  @default(now()) @map("evaluated_at")

  @@index([workspaceId, ruleId, accountId])
  @@map("routing_rule_evaluations")
}

model StageChangeLog {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  accountId   String   @map("account_id")
  fromStage   String   @map("from_stage")
  toStage     String   @map("to_stage")
  score       Int
  changedAt   DateTime @default(now()) @map("changed_at")

  @@index([workspaceId, accountId])
  @@map("stage_change_log")
}
