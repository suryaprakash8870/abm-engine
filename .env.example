# ─────────────────────────────────────────────────────────────
# ABM Engine — environment variable template.
# Copy to .env and fill in. NEVER commit a populated .env.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ──
# For local dev with docker compose, use the docker URL.
# For Supabase, use the connection string from the Supabase dashboard.
DATABASE_URL=postgres://abm:abm@localhost:5432/abm
DIRECT_URL=postgres://abm:abm@localhost:5432/abm

# ── Supabase (auth + RLS) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis (BullMQ) ──
REDIS_URL=redis://localhost:6379

# ── Encryption for CRM tokens at rest ──
# 32-byte (base64) key. Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# ── API ──
API_PORT=4000
API_BASE_URL=http://localhost:4000

# ── Web ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── CRM / integrations (filled in Phase 1) ──
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=

# ── Enrichment (filled in Phase 1 — verify pricing live, see ADR-014) ──
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# ── Slack alerts (filled in Phase 3) ──
SLACK_BOT_TOKEN=
