# ─────────────────────────────────────────────────────────────────────────────
# ABM Engine — environment template. Copy to .env.local and fill in.
# NEVER commit a populated env file. See docs/project/environment.md for where
# to get each credential. Server-only secrets MUST NOT have the NEXT_PUBLIC_ prefix.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase (Postgres + Auth + RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to client
DATABASE_URL=                       # Postgres connection string (pooled)
DIRECT_URL=                         # Postgres direct connection (for migrations)

# Anthropic (Sonnet for reasoning, Haiku for batch — ADR-009)
ANTHROPIC_API_KEY=                  # sk-ant-... (ICP synth ~5c/build on Sonnet, ~fraction of a cent on Haiku)
# ICP synthesis provider for local testing:
#   (empty) = real Claude (production)   |   mock = deterministic sample, no LLM
#   ollama  = local Ollama (free, real LLM) — see OLLAMA_* below
ICP_LLM=                            # mock | ollama | (empty = Claude)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b           # low-memory (~1GB). Pull: `ollama pull qwen2.5:1.5b`

# Data APIs
# Apollo (Engine 02 TAM). Unset = free MOCK companies. Set a key for real data.
# TAM_ACCOUNT_LIMIT caps companies per build — keep SMALL on credit-limited plans.
APOLLO_API_KEY=
TAM_ACCOUNT_LIMIT=                  # e.g. 10 when testing a real Apollo key
CLEARBIT_API_KEY=
BUILTWITH_API_KEY=
RB2B_API_KEY=

# HubSpot OAuth app
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_WEBHOOK_SECRET=

# Salesforce (v1.1)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Slack app
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_SCALE_MONTHLY=

# Redis (Upstash) — BullMQ event bus needs the TCP connection (ioredis).
# Upstash dashboard → Database → Connect → ioredis gives a rediss:// URL.
REDIS_URL=                          # rediss://default:<token>@<host>:<port>
# REST client (for dedup / rate-limit caches via @upstash/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email
RESEND_API_KEY=
EMAIL_FROM=hello@yourdomain.com

# Telegram alerts (Engine 09) — workspace-wide default. Per-workspace keys can be
# set in the Integrations hub instead (format botToken;chatId). Create a bot via
# @BotFather; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web research — Firecrawl (3rd-party signals, Engines 03 · 07). Server-only secret.
# Leave unset (or FIRECRAWL_SOURCE=mock) for free deterministic mock crawls.
FIRECRAWL_API_KEY=
# FIRECRAWL_SOURCE=mock

# TheirStack — job postings + technographics → hiring/tech signals (Engine 07).
# Free tier: 200 API credits/mo. Leave unset (or THEIRSTACK_SOURCE=mock) for mock.
THEIRSTACK_API_KEY=
# THEIRSTACK_SOURCE=mock

# AI-Ark — B2B company/people data + enrichment API (Engines 02 · 03). Free: 100/mo.
AI_ARK_API_KEY=

# Google OAuth (login/signup with Google). Create OAuth 2.0 credentials at
# console.cloud.google.com → APIs & Services → Credentials. Authorized redirect URI:
#   <app-origin>/api/v1/auth/google/callback  (e.g. http://localhost:3000/api/v1/auth/google/callback)
# Leave unset to hide/disable Google sign-in (email/password still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Analytics + errors
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Security
ENCRYPTION_KEY=                     # 32-byte hex, generate: openssl rand -hex 32
AUTH_SECRET=                        # session-cookie signing key (falls back to ENCRYPTION_KEY)
NEXT_PUBLIC_TRACKER_CDN_URL=        # CDN URL for tracker.js
