# requests. Set this to the seeded OneGTMLab org UUID so the dashboard works
# without auth. Replaced by Supabase JWT in Phase 1.5.
NEXT_PUBLIC_DEV_ORG_ID=00000000-0000-0000-0000-000000000001

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
